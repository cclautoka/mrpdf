{
  "name": "@mr-pdf/pdf-core",
  "version": "0.1.0",
  "description": "Client-side PDF processing engine (pdf-lib + pdf.js) with a Web Worker harness.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./worker": "./src/worker/worker.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.10.38",
    "@pdf-lib/fontkit": "^1.1.1"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  }
}
