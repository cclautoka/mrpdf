# ---- Frontend (apps/web) ----
# Base URL of the backend job API used by server-side tools.
NEXT_PUBLIC_API_URL=http://localhost:8080

# ---- Backend (apps/api) ----
# HTTP server
PORT=8080
HOST=0.0.0.0

# Redis connection for the BullMQ job queue
REDIS_URL=redis://127.0.0.1:6379

# CORS origin allowed to call the API (the web app URL)
CORS_ORIGIN=http://localhost:3000

# Where per-job temp files are stored, and how long to keep them (ms)
STORAGE_DIR=./storage
JOB_TTL_MS=3600000

# Max upload size in bytes (default 200 MB)
MAX_UPLOAD_BYTES=209715200

# Run the queue worker inside the API process (set to "false" to use a separate worker)
INLINE_WORKER=true
WORKER_CONCURRENCY=2
