{
  "name": "@mr-pdf/api",
  "version": "0.1.0",
  "private": true,
  "description": "MR PDF backend: job queue + CLI-powered heavy PDF conversions.",
  "license": "MIT",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "worker": "tsx src/worker-process.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/multipart": "^9.0.1",
    "bullmq": "^5.34.5",
    "fastify": "^5.2.0",
    "ioredis": "^5.4.2",
    "markdown-it": "^14.1.0",
    "nanoid": "^5.0.9",
    "playwright": "^1.49.1"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
